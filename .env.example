# Copy this file to .env for local development.

# Local server
PORT=3000
BASE_URL=http://localhost:3000
DATA_DIR=./data

# Keep true for local end-to-end demo without real money or crypto.
# Set false only after you have approved Transak credentials and a public HTTPS domain.
DEMO_MODE=true

# Transak provider configuration. Required when DEMO_MODE=false.
# Use the API Key and API Secret from the Transak Partner Dashboard > Developers page.
# The backend will exchange API Key + API Secret for a Partner Access Token and cache it.
TRANSAK_ENV=STAGING
TRANSAK_API_KEY=your_transak_api_key
TRANSAK_API_SECRET=your_transak_api_secret
TRANSAK_REFERRER_DOMAIN=localhost:3000

# Optional: only set this if Transak support gives you a pre-generated Partner Access Token.
# Usually leave it empty and let the server generate/cache the token with TRANSAK_API_SECRET.
# TRANSAK_ACCESS_TOKEN=your_transak_partner_access_token

# Optional: false means the buyer can switch payment method inside Transak.
# true means card/apple_pay/google_pay preferences are locked with widgetParams.paymentMethod.
TRANSAK_LOCK_PAYMENT_METHOD=false

# Optional endpoint overrides for local tests or if Transak support gives you environment-specific URLs.
# TRANSAK_REFRESH_TOKEN_URL=https://api-stg.transak.com/partners/api/v2/refresh-token
# TRANSAK_WIDGET_SESSION_URL=https://api-gateway-stg.transak.com/api/v2/auth/session

# Optional brand/display settings
APP_NAME=Direct Crypto Pay
SUPPORT_EMAIL=support@example.com

# Optional hard caps for your own UI. Provider limits still apply.
MIN_FIAT_AMOUNT=10
MAX_FIAT_AMOUNT=25000
